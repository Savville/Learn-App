# Frontend Environment Variables (Example)
# Copy this to .env and .env.local and update values

# Backend API URL - Development
VITE_API_URL=http://localhost:5000/api

# Backend API URL - Production (uncomment when deploying)
# VITE_API_URL=https://learn-opportunities-api.railway.app/api

# Password to access the Admin Dashboard UI.
# IMPORTANT: This provides basic protection, not high security.
VITE_ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD_HERE"

# Environment
VITE_ENV=development

# --- Backend Environment Variables ---
# These are NOT used by the frontend.
# Copy them to a separate .env file inside the /backend folder.

# Gemini API Key for the intelligent parser
# Get one from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Secure key for accessing the admin-only API endpoints
ADMIN_API_KEY="YOUR_ADMIN_API_KEY_HERE"
